FROM public.ecr.aws/docker/library/debian:trixie-slim AS runtime-base
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /app

FROM runtime-base AS client
COPY --from=client-builder /app/base-client ./base-client
ENTRYPOINT ["./base-client"]

FROM runtime-base AS base
COPY --from=base-builder /app/base ./base
ENTRYPOINT ["./base"]

FROM runtime-base AS builder
COPY --from=builder-builder /app/base-builder ./base-builder
ENTRYPOINT ["./base-builder"]

FROM runtime-base AS consensus
COPY --from=consensus-builder /app/base-consensus ./base-consensus
ENTRYPOINT ["./base-consensus"]

FROM runtime-base AS proposer
COPY --from=proposer-builder /app/base-proposer ./base-proposer
EXPOSE 9090
ENTRYPOINT ["./base-proposer"]

FROM runtime-base AS websocket-proxy
COPY --from=websocket-proxy-builder /app/websocket-proxy ./websocket-proxy
ENTRYPOINT ["./websocket-proxy"]

FROM runtime-base AS ingress-rpc
COPY --from=ingress-rpc-builder /app/ingress-rpc ./ingress-rpc
ENTRYPOINT ["./ingress-rpc"]

FROM runtime-base AS audit-archiver
COPY --from=audit-archiver-builder /app/audit-archiver ./audit-archiver
ENTRYPOINT ["./audit-archiver"]

FROM runtime-base AS batcher
COPY --from=batcher-builder /app/base-batcher ./base-batcher
ENTRYPOINT ["./base-batcher"]

FROM runtime-base AS zk-prover
COPY --from=zk-prover-builder /app/base-prover-zk ./base-prover-zk
EXPOSE 9000
ENTRYPOINT ["./base-prover-zk"]
